---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
}

const {
  title,
  description = 'With over 45 years of full-time proofreading experience, Lynden Howells delivers accurate, personal proofreading and editorial services. Based in Hobart, Tasmania, serving clients across Australia and internationally. No AI tools, no subcontractors.',
  canonical,
} = Astro.props;

const siteUrl = 'https://lyndensproofreading.com';
const canonicalUrl = canonical ?? (siteUrl + Astro.url.pathname);
const isHome = Astro.url.pathname === '/';

const fullTitle = isHome
  ? "Lynden's Proofreading | Professional Proofreader, Hobart Tasmania"
  : `${title} | Lynden's Proofreading`;

const ogImage = `${siteUrl}/lynden.jpeg`;

const nav = [
  { href: '/',         label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/faq',      label: 'FAQ' },
  { href: '/contact',  label: 'Contact' },
];

const breadcrumb = !isHome ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": title, "item": canonicalUrl },
  ]
} : null;
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Lynden Howells, professional proofreader" />
    <meta property="og:image:width" content="180" />
    <meta property="og:image:height" content="240" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:site_name" content="Lynden's Proofreading" />

    <!-- Twitter/X Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Lynden Howells, professional proofreader" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- LocalBusiness structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Lynden's Proofreading",
      "description": description,
      "url": siteUrl,
      "image": ogImage,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hobart",
        "addressRegion": "TAS",
        "addressCountry": "AU"
      },
      "areaServed": [
        "Tasmania", "Victoria", "New South Wales", "Queensland",
        "South Australia", "Western Australia", "Australia", "United States", "Japan"
      ],
      "priceRange": "$$",
      "knowsLanguage": "en-AU",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Proofreading and Editorial Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Proofreading" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Copyediting" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tender Document Review" } }
        ]
      },
      "founder": {
        "@type": "Person",
        "name": "Lynden Howells",
        "jobTitle": "Professional Proofreader and Copyeditor",
        "worksFor": { "@type": "LocalBusiness", "name": "Lynden's Proofreading" }
      }
    })} />

    <!-- Breadcrumb structured data (interior pages) -->
    {breadcrumb && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
    )}
  </head>
  <body>
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav__inner">
        <a href="/" class="site-nav__brand">Lynden's Proofreading</a>
        <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <ul class="site-nav__links" id="nav-links">
          {nav.map(({ href, label }) => (
            <li>
              <a href={href} aria-current={Astro.url.pathname === href ? 'page' : undefined}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div>
          <div class="site-footer__brand">Lynden's Proofreading</div>
          <div class="site-footer__tagline">Excellence in proofreading for over 45 years</div>
          <p style="margin-top:0.75rem;font-size:0.85rem;">Hobart, Tasmania, Australia</p>
        </div>
        <ul class="site-footer__links">
          {nav.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>
      </div>
      <div class="site-footer__bottom">
        &copy; {new Date().getFullYear()} Lynden Howells. All rights reserved.
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
      const links = document.getElementById('nav-links')!;
      toggle?.addEventListener('click', () => {
        const open = links.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
      });
    </script>
  </body>
</html>
