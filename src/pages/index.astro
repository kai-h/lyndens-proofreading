---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__content">
        <p class="hero__eyebrow">Hobart, Tasmania &amp; Australia-wide</p>
        <h1>Excellence in<br />Proofreading</h1>
        <p class="hero__sub">
          Over 35 years of full-time experience ensuring your documents are accurate,
          polished, and ready to represent you at your best.
        </p>
        <a href="/contact" class="hero__cta">Get in Touch</a>
      </div>
      <div class="hero__photo">
        <img src="/lynden.jpeg" alt="Lynden Howells, proofreader and copyeditor" width="180" height="180" />
      </div>
    </div>
  </section>

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <h2>Your reputation is on the line</h2>
      <hr class="gold-rule" />
      <p style="font-size:1.1rem;max-width:680px;">
        Before you print, publish, or present — proof it first. Spell-checkers catch spelling,
        but they don't catch the wrong word in the right place, inconsistent formatting, or the
        embarrassing error on page one of your annual report.
      </p>
      <p>
        Lynden Howells has spent over 35 years doing exactly this — full-time, professionally,
        with an eye for the details that matter. Clients across government, healthcare, education,
        and the private sector trust Lynden to find what they've missed.
      </p>

      <div class="highlight-box">
        <p style="font-size:1.05rem;font-style:italic;margin:0;">
          "Bring me into the mix, so I can supply the proof."
        </p>
        <p style="margin-top:0.5rem;font-weight:700;font-size:0.9rem;">— Lynden Howells</p>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section section--alt">
    <div class="container">
      <h2>What I do</h2>
      <hr class="gold-rule" />
      <div class="cards">
        <div class="card">
          <h3>Proofreading</h3>
          <p>
            Careful, thorough review of your documents for spelling, grammar, punctuation,
            consistency, and correct word usage — catching what spellcheck can't.
          </p>
          <a href="/services">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>Editorial Services</h3>
          <p>
            Beyond error-checking — suggestions for clearer phrasing and improved readability,
            with you always retaining final say on any changes.
          </p>
          <a href="/services">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>Tender Documents</h3>
          <p>
            Tenders rejected on technicalities represent real cost. I review for omissions,
            contradictions, and presentation issues to strengthen your submission.
          </p>
          <a href="/tenders">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="section">
    <div class="container">
      <h2>What clients say</h2>
      <hr class="gold-rule" />
      <div class="testimonial">
        <blockquote>
          "I have been amazed at how accurate his work is (and how inaccurate my writing can be).
          I highly recommend his services to all those who are particular with the accuracy of their written work."
        </blockquote>
        <p class="testimonial__author">Michael C Dyson</p>
        <p class="testimonial__role">Managing Director, Dyson Corporate Security Pty Ltd</p>
      </div>
      <a href="/testimonials" class="btn mt-2">Read more testimonials</a>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="section section--alt">
    <div class="container" style="text-align:center;">
      <h2>Ready to get started?</h2>
      <p style="max-width:480px;margin:1rem auto 2rem;">
        Send me a sample of your work and I'll provide a quote. Turnaround is typically
        24–48 hours for a standard 20-page document.
      </p>
      <a href="/contact" class="btn">Contact Lynden</a>
    </div>
  </section>
</Layout>
