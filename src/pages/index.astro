---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero with header image -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <div class="hero__inner">
      <div>
        <p class="hero__eyebrow">Hobart, Tasmania &amp; Australia-wide</p>
        <h1>Excellence in<br />Proofreading</h1>
        <p class="hero__sub">
          Over 45 years of full-time experience ensuring your documents are accurate,
          polished, and ready to represent you at your best.
        </p>
        <a href="/contact" class="hero__cta">Get in Touch</a>
      </div>
      <div class="hero__photo">
        <img
          src="/lynden.jpeg"
          alt="Lynden Howells, professional proofreader"
          width="200"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Intro / About -->
  <section class="section">
    <div class="container">
      <h2>Your reputation is on the line</h2>
      <hr class="gold-rule" />
      <p style="font-size:1.05rem;max-width:680px;">
        Before you print, publish, or send – proof it first. Spell-checkers catch spelling,
        but they don't catch the wrong word in the right place, inconsistent formatting, or the
        error that ends up on the cover of your annual report.
      </p>
      <p>
        I'm Lynden Howells, based in Hobart, Tasmania. I've worked full-time in proofreading
        and publishing for over 45 years – with clients ranging from government departments and
        universities to advertising agencies and healthcare companies across Australia.
      </p>
      <p>
        My clients include The Federal Group Tasmania, the University of Tasmania,
        Clemenger Tasmania, Hobart College, and the Department of Health and Human Services.
        The work spans annual reports, scientific journals, tender documents, legal contracts,
        brochures, and healthcare prescribing information.
      </p>

      <div class="highlight-box">
        <p style="font-size:1.1rem;font-family:'DM Serif Display',Georgia,serif;font-style:italic;margin:0;">
          "Bring me into the mix, so I can supply the proof."
        </p>
        <p style="margin-top:0.6rem;font-size:0.85rem;font-weight:500;color:var(--brown);">– Lynden Howells</p>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="section section--alt">
    <div class="container">
      <h2>What I do</h2>
      <hr class="gold-rule" />
      <div class="cards">
        <div class="card">
          <h3>Proofreading</h3>
          <p>
            A trained eye for spelling, grammar, punctuation, consistency, and word usage –
            catching what spellcheck simply cannot.
          </p>
          <a href="/services#proofreading">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>Editorial Services</h3>
          <p>
            Suggestions for clearer, sharper phrasing and improved readability, with you
            always retaining final say on every change.
          </p>
          <a href="/services#editorial">Learn more &rarr;</a>
        </div>
        <div class="card">
          <h3>Tender Documents</h3>
          <p>
            Tenders rejected on technicalities represent real cost. I review for omissions,
            contradictions, and errors that can sink a strong submission.
          </p>
          <a href="/services#tenders">Learn more &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial + CTA -->
  <section class="section">
    <div class="container">
      <h2>What clients say</h2>
      <hr class="gold-rule" />
      <div class="testimonial">
        <blockquote>
          "I have been amazed at how accurate his work is – and how inaccurate my writing can be.
          I highly recommend his services to all those who are particular with the accuracy of their written work."
        </blockquote>
        <p class="testimonial__author">Michael C Dyson</p>
        <p class="testimonial__role">Managing Director, Dyson Corporate Security Pty Ltd</p>
      </div>
      <a href="/testimonials">Read more testimonials &rarr;</a>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="section section--dark">
    <div class="container" style="text-align:center;">
      <h2>Ready to get started?</h2>
      <p style="max-width:460px;margin:1rem auto 2rem;font-weight:300;">
        Send me a sample and I'll provide a quote. Typical turnaround is
        2–3 business days for a standard 20-page document, with rush jobs available on request.
      </p>
      <a href="/contact" class="btn btn--gold">Contact Lynden</a>
    </div>
  </section>
</Layout>
