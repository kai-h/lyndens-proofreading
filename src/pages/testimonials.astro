---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Testimonials"
  description="Hear what clients say about Lynden Howells — professional proofreader and copyeditor with over 45 years of experience, based in Hobart, Tasmania."
>
  <div class="page-header">
    <div class="container">
      <h1>Testimonials</h1>
      <p class="page-header__sub">What clients say about working with Lynden</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="testimonial">
        <blockquote>
          "I have used, and will continue to use, Lynden's proofreading services to check my
          tender documents and other technical reports I write for my clients. I have been amazed
          at how accurate his work is — and how inaccurate my writing can be. I highly recommend
          his services to all those who are particular with the accuracy of their written work."
        </blockquote>
        <p class="testimonial__author">Michael C Dyson</p>
        <p class="testimonial__role">Managing Director, Dyson Corporate Security Pty Ltd</p>
      </div>

      <div class="testimonial">
        <blockquote>
          "Thank you for the proofreading work you have done for me. I offer to be a referee
          for your services and will be in touch for future projects."
        </blockquote>
        <p class="testimonial__author">Ben Ross</p>
        <p class="testimonial__role">Health Promotion Officer, Gambling Support Program, Department of Health and Human Services</p>
      </div>

      <div class="highlight-box" style="margin-top:2.5rem;">
        <p style="margin:0;">
          Ready to work with Lynden? <a href="/contact">Get in touch</a> to discuss your
          project and request a quote.
        </p>
      </div>
    </div>
  </section>
</Layout>
